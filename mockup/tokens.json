{
  "$schema": "https://design-tokens.org/schema.json",
  "$meta": {
    "name": "Metra Design Tokens",
    "version": "0.1.0",
    "license": "GPL-3.0-only",
    "description": "Design tokens per Métra. Sorgente unica condivisa con tokens.css. Importabile in Dart const via script in P-0.",
    "naming": "Le chiavi colore in 'colors.light' e 'colors.dark' mappano 1:1 a campi statici della classe MetraColors in lib/core/theme/metra_colors.dart.",
    "contrastReference": "WCAG 2.2 AA: small text >=4.5:1, large text/UI >=3:1. Verifica annotata su ogni coppia significativa.",
    "antiPatterns": [
      "no glassmorphism",
      "no neumorphism",
      "no aggressive gradients",
      "no pastel pink",
      "no gamification colors",
      "no pure black on pure white"
    ]
  },

  "colors": {
    "light": {
      "sand":              "#F4EDE2",
      "terracotta":        "#C87456",
      "terracottaDeep":    "#9B4E32",
      "dustyOchre":        "#D4A26A",
      "dustyOchreDeep":    "#8A6332",
      "nightLavender":     "#5B4E7A",
      "moss":              "#7A8471",
      "mossDeep":          "#4F5A47",
      "ink":               "#2B2521",
      "inkSoft":           "#5A4F47",
      "surfaceRaised":     "#FBF6EC",
      "surfaceSunken":     "#ECE4D6",
      "divider":           "#DCD2C0",
      "overlayScrim":      "rgba(43,37,33,0.32)",
      "textDisabled":      "#8C8378"
    },
    "dark": {
      "deepNight":             "#1A1410",
      "deepNightRaised":       "#241D17",
      "deepNightSunken":       "#15100C",
      "mutedTerracotta":       "#B86848",
      "mutedTerracottaSoft":   "#D88B6E",
      "lightLavender":         "#9B8FBF",
      "warmOchreDark":         "#C09060",
      "mossDark":              "#8A9580",
      "ivory":                 "#EDE4D3",
      "ivorySoft":             "#C8BFAE",
      "dividerDark":           "#382E26",
      "overlayScrim":          "rgba(0,0,0,0.56)",
      "textDisabled":          "#6B6358"
    },

    "semantic": {
      "light": {
        "bgPrimary":             "{colors.light.sand}",
        "bgSurface":             "{colors.light.surfaceRaised}",
        "bgSunken":              "{colors.light.surfaceSunken}",
        "bgOverlay":             "{colors.light.overlayScrim}",
        "textPrimary":           "{colors.light.ink}",
        "textSecondary":         "{colors.light.inkSoft}",
        "textOnSand":            "{colors.light.terracottaDeep}",
        "textOnAccent":          "{colors.light.sand}",
        "textDisabled":          "{colors.light.textDisabled}",
        "accentFlow":            "{colors.light.terracotta}",
        "accentFlowStrong":      "{colors.light.terracottaDeep}",
        "accentPrediction":      "{colors.light.nightLavender}",
        "accentWarmth":          "{colors.light.dustyOchre}",
        "accentWarmthStrong":    "{colors.light.dustyOchreDeep}",
        "accentConfirmation":    "{colors.light.moss}",
        "accentConfirmationStrong": "{colors.light.mossDeep}",
        "borderSubtle":          "{colors.light.divider}",
        "borderStrong":          "{colors.light.inkSoft}",
        "stateError":            "{colors.light.terracottaDeep}",
        "stateSuccess":          "{colors.light.mossDeep}",
        "stateWarning":          "{colors.light.dustyOchreDeep}",
        "focusRing":             "{colors.light.nightLavender}"
      },
      "dark": {
        "bgPrimary":             "{colors.dark.deepNight}",
        "bgSurface":             "{colors.dark.deepNightRaised}",
        "bgSunken":              "{colors.dark.deepNightSunken}",
        "bgOverlay":             "{colors.dark.overlayScrim}",
        "textPrimary":           "{colors.dark.ivory}",
        "textSecondary":         "{colors.dark.ivorySoft}",
        "textOnSand":            "{colors.dark.mutedTerracottaSoft}",
        "textOnAccent":          "{colors.dark.deepNight}",
        "textDisabled":          "{colors.dark.textDisabled}",
        "accentFlow":            "{colors.dark.mutedTerracotta}",
        "accentFlowStrong":      "{colors.dark.mutedTerracottaSoft}",
        "accentPrediction":      "{colors.dark.lightLavender}",
        "accentWarmth":          "{colors.dark.warmOchreDark}",
        "accentWarmthStrong":    "{colors.dark.warmOchreDark}",
        "accentConfirmation":    "{colors.dark.mossDark}",
        "accentConfirmationStrong": "{colors.dark.mossDark}",
        "borderSubtle":          "{colors.dark.dividerDark}",
        "borderStrong":          "{colors.dark.ivorySoft}",
        "stateError":            "{colors.dark.mutedTerracottaSoft}",
        "stateSuccess":          "{colors.dark.mossDark}",
        "stateWarning":          "{colors.dark.warmOchreDark}",
        "focusRing":             "{colors.dark.lightLavender}"
      }
    },

    "contrastChecks": [
      { "fg": "ink",                    "bg": "sand",       "ratio": "12.4:1", "wcag": "AAA", "usage": "body text light" },
      { "fg": "inkSoft",                "bg": "sand",       "ratio": "6.9:1",  "wcag": "AA",  "usage": "secondary text light" },
      { "fg": "terracottaDeep",         "bg": "sand",       "ratio": "5.6:1",  "wcag": "AA",  "usage": "accent text light" },
      { "fg": "nightLavender",          "bg": "sand",       "ratio": "6.8:1",  "wcag": "AA",  "usage": "prediction text light" },
      { "fg": "dustyOchreDeep",         "bg": "sand",       "ratio": "4.7:1",  "wcag": "AA",  "usage": "warmth text light" },
      { "fg": "mossDeep",               "bg": "sand",       "ratio": "7.1:1",  "wcag": "AA",  "usage": "confirmation text light" },
      { "fg": "terracotta",             "bg": "sand",       "ratio": "3.0:1",  "wcag": "AA-large-only", "usage": "decorative fill / large UI light" },
      { "fg": "dustyOchre",             "bg": "sand",       "ratio": "2.0:1",  "wcag": "FAIL", "usage": "decorative only — never text" },
      { "fg": "ivory",                  "bg": "deepNight",  "ratio": "13.2:1", "wcag": "AAA", "usage": "body text dark" },
      { "fg": "ivorySoft",              "bg": "deepNight",  "ratio": "9.4:1",  "wcag": "AA",  "usage": "secondary text dark" },
      { "fg": "mutedTerracottaSoft",    "bg": "deepNight",  "ratio": "6.0:1",  "wcag": "AA",  "usage": "accent text dark" },
      { "fg": "lightLavender",          "bg": "deepNight",  "ratio": "5.5:1",  "wcag": "AA",  "usage": "prediction text dark" },
      { "fg": "warmOchreDark",          "bg": "deepNight",  "ratio": "5.6:1",  "wcag": "AA",  "usage": "warmth text dark" },
      { "fg": "mossDark",               "bg": "deepNight",  "ratio": "5.0:1",  "wcag": "AA",  "usage": "confirmation text dark" },
      { "fg": "mutedTerracotta",        "bg": "deepNight",  "ratio": "3.9:1",  "wcag": "AA-large-only", "usage": "decorative fill dark" }
    ]
  },

  "typography": {
    "fonts": {
      "display":  "DM Serif Display",
      "body":     "Inter",
      "fallbacks": {
        "display": ["Cormorant Garamond", "Georgia", "serif"],
        "body":    ["-apple-system", "BlinkMacSystemFont", "Segoe UI", "Roboto", "sans-serif"]
      }
    },
    "weights": {
      "regular":  400,
      "medium":   500,
      "semibold": 600
    },
    "scale": {
      "displayXl": { "size": 48, "lineHeight": 1.2,  "letterSpacing": "-0.01em", "font": "display" },
      "displayLg": { "size": 40, "lineHeight": 1.2,  "letterSpacing": "-0.01em", "font": "display" },
      "displayMd": { "size": 32, "lineHeight": 1.2,  "letterSpacing": "-0.01em", "font": "display" },
      "titleLg":   { "size": 26, "lineHeight": 1.3,  "letterSpacing": "0",       "font": "display" },
      "titleMd":   { "size": 22, "lineHeight": 1.3,  "letterSpacing": "0",       "font": "display" },
      "titleSm":   { "size": 20, "lineHeight": 1.3,  "letterSpacing": "0",       "font": "body",    "weight": "semibold" },
      "bodyLg":    { "size": 18, "lineHeight": 1.5,  "letterSpacing": "0",       "font": "body",    "weight": "regular" },
      "body":      { "size": 16, "lineHeight": 1.5,  "letterSpacing": "0",       "font": "body",    "weight": "regular" },
      "caption":   { "size": 13, "lineHeight": 1.4,  "letterSpacing": "0.01em",  "font": "body",    "weight": "regular" },
      "tiny":      { "size": 12, "lineHeight": 1.4,  "letterSpacing": "0.01em",  "font": "body",    "weight": "medium"  }
    }
  },

  "spacing": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "5": 20,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64
  },

  "radius": {
    "sm":     8,
    "md":     12,
    "lg":     16,
    "pill":   999,
    "circle": "50%"
  },

  "motion": {
    "durations": {
      "instant":     0,
      "fast":        150,
      "base":        240,
      "slow":        400,
      "risingFill":  600,
      "painPulse":   780
    },
    "reducedMotionDurations": {
      "instant":     0,
      "fast":        0,
      "base":        0,
      "slow":        80,
      "risingFill":  80,
      "painPulse":   0
    },
    "easings": {
      "standard":    "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
      "emphasized":  "cubic-bezier(0.2, 0, 0, 1)",
      "decelerate":  "cubic-bezier(0, 0, 0.2, 1)",
      "accelerate":  "cubic-bezier(0.4, 0, 1, 1)",
      "pulse":       "cubic-bezier(0.4, 0, 0.6, 1)"
    }
  },

  "elevation": {
    "none":  "none",
    "card":  {
      "light": "0 1px 2px rgba(43,37,33,0.08), 0 0 0 1px rgba(43,37,33,0.03)",
      "dark":  "0 1px 2px rgba(0,0,0,0.4), 0 0 0 1px rgba(237,228,211,0.04)"
    },
    "modal": {
      "light": "0 8px 24px rgba(43,37,33,0.16)",
      "dark":  "0 8px 24px rgba(0,0,0,0.6)"
    }
  },

  "layout": {
    "maxWidth":      420,
    "contentPad":    24,
    "tapTargetMin":  44,
    "tapTargetMd":   48
  },

  "focus": {
    "ringWidth":  2,
    "ringOffset": 2,
    "ringColor":  "{colors.semantic.light.focusRing}"
  },

  "zIndex": {
    "base":   0,
    "raised": 1,
    "sticky": 10,
    "modal":  100,
    "toast":  200
  }
}
